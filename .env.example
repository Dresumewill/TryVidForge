
# ── Supabase ─────────────────────────────────────────────────────────────────
# Project API settings: https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, NEVER prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI Provider ───────────────────────────────────────────────────────────────
# Anthropic is preferred. Set ANTHROPIC_API_KEY to use Claude 3.5 Haiku.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI is the fallback if ANTHROPIC_API_KEY is not set.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Stripe ────────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # from: stripe listen --print-secret

# One-time Price IDs — create in Stripe Dashboard → Products → Add product
# Currency: EUR  |  Type: One time
STRIPE_PRICE_STARTER=price_...   # 50 credits   €10
STRIPE_PRICE_CREATOR=price_...   # 150 credits  €25

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # production: https://yourdomain.com

# ── Cron ─────────────────────────────────────────────────────────────────────
# Vercel sets Authorization: Bearer <CRON_SECRET> on cron requests automatically
CRON_SECRET=generate-a-random-secret-here

# ── ElevenLabs (text-to-speech) ───────────────────────────────────────────────
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_...
# Optional — defaults to "Rachel" (21m00Tcm4TlvDq8ikWAM)
# Browse voices: https://elevenlabs.io/voice-library
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Runway ML (video rendering) ───────────────────────────────────────────────
# https://app.runwayml.com/settings/api-keys
RUNWAY_API_KEY=...
# Optional overrides (defaults shown):
# RUNWAY_MODEL=gen4_turbo          # gen4_turbo | gen3a_turbo
# RUNWAY_DURATION=5                # 5 | 10  (seconds)
# RUNWAY_RATIO=1280:768            # 1280:768 (16:9) | 768:1280 (9:16 vertical)
